---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal website of Josh Gachnang" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="container">
      <header>
        <nav>
          <a href="/" class="site-title">Josh Gachnang</a>
          <ul class="nav-links">
            <li><a href="/about">About</a></li>
            <li><a href="/roman-eulogy">Roman Eulogy</a></li>
          </ul>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        <p>&copy; {new Date().getFullYear()} Josh Gachnang</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
